# Required environment variables for the OSCAL Compliance Pipeline
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── TLS / SSL ────────────────────────────────────────────────────────────────
# Leave unset to use the system trust store (correct for most environments).
# Set to a file path only if your network uses SSL inspection with a custom CA.
# CA_BUNDLE=/etc/ssl/certs/corporate-ca-bundle.crt

# ── Cloud Security Platform (e.g., Wiz) ──────────────────────────────────────
WIZ_CLIENT_ID=your_wiz_client_id
WIZ_CLIENT_SECRET=your_wiz_client_secret
WIZ_API_URL=https://api.<your-tenant>.wiz.io/graphql
WIZ_TOKEN_URL=https://auth.app.wiz.io/oauth/token

# ── Issue Tracker (e.g., Jira) ────────────────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_TOKEN=your_jira_api_token
JIRA_USERNAME=your.email@your-org.com    # Required for cloud Jira, omit for on-prem
JIRA_PROJECTS=PROJ1,PROJ2,PROJ3
JIRA_SIA_FIELD=customfield_10000         # Discover with: GET /rest/api/2/field
JIRA_LOOKBACK_DAYS=90

# ── Endpoint Management (e.g., Tanium) ───────────────────────────────────────
TANIUM_URL=https://your-tanium-instance.domain.com
TANIUM_TOKEN=your_tanium_api_token

# ── SIEM (e.g., Splunk) ───────────────────────────────────────────────────────
SPLUNK_URL=https://your-splunk-instance:8089
SPLUNK_TOKEN=your_splunk_hec_token

# ── Identity Governance (e.g., SailPoint) ────────────────────────────────────
SAILPOINT_URL=https://your-tenant.identitynow.com
SAILPOINT_CLIENT_ID=your_client_id
SAILPOINT_CLIENT_SECRET=your_client_secret

# ── Source Control (e.g., Bitbucket) ─────────────────────────────────────────
BITBUCKET_URL=https://your-bitbucket-instance.domain.com
BITBUCKET_TOKEN=your_access_token

# ── GRC Agent LLM Backend ────────────────────────────────────────────────────
# Options: bedrock | ollama | openai | anthropic
GRC_AGENT_BACKEND=bedrock
GRC_AGENT_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
AWS_REGION=us-gov-west-1
